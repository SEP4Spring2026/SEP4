# Copy this file to `.env` and adjust the values for your environment.
# `.env` is gitignored — never commit real secrets.

# --- MySQL ---
MYSQL_DATABASE=kamtjatka
MYSQL_USER=kamtjatka
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-too

# Host port mysql is bound to (loopback only). Set to 0 to disable host binding.
MYSQL_HOST_PORT=3306

# --- MainServer (.NET) ---
MAIN_SERVER_PORT=8080
ASPNETCORE_ENVIRONMENT=Production

# --- ML Server (FastAPI) ---
# Public URL of the ML server. Use the in-cluster name when running it locally
# via the `local` profile, or your cloud HTTPS URL otherwise.
#   local:  http://ml-server:8000
#   cloud:  https://your-ml-app.onrender.com
ML_SERVER_URL=http://ml-server:8000

# Only used by the local profile (when running ml-server in this compose stack).
ML_SERVER_PORT=8000
