# Copy this file to `.env` and adjust the values for your environment.
# `.env` is gitignored — never commit real secrets.

# --- MySQL ---
MYSQL_DATABASE=kamtjatka
MYSQL_USER=kamtjatka
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-too

# Host port mysql is bound to (loopback only). Set to 0 to disable host binding.
MYSQL_HOST_PORT=3306

# --- MainServer (.NET) ---
MAIN_SERVER_PORT=8080
ASPNETCORE_ENVIRONMENT=Production

# --- ML Server (FastAPI) ---
# Default: shared team ML server hosted on the cloud — you do not need to run
# it yourself. Override only if you want to run a local ML container too:
#   local profile:  http://ml-server:8000
ML_SERVER_URL=http://159.195.147.132:8000

# Only used when starting the optional local ml-server (compose --profile local).
ML_SERVER_PORT=8000
